min-height:25px;
max-height:25px; 
            }
QCheckBox{
  background-color: white;
                color: black;
                border: 1px solid #aaa;
                border-radius:2px; 
}
            
            QComboBox:hover,QDateEdit:focus,QLineEdit:focus,QComboBox:focus,QCheckBox:focus {
                
                border: 1px solid #007bff;
            }
                                        
            QComboBox:disabled::drop-down, QDateEdit:disabled::drop-down{
                background: transparent;
            }

            
            QComboBox:disabled {
                background-color: #afafaf;  /* Gris clair */
                color: #f0f0f0;  /* Texte grisé */
