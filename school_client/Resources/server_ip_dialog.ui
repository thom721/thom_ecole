}



QLineEdit,
QComboBox,
QDateEdit {
    background: #fff
}

QComboBox QListView {
    font-size: 12px;
    padding: 4px;
    background-color: #fefefe;
}

QLineEdit,QComboBox {
    border: none;
    border-bottom: 2px solid #1266f1
}


#valider_id_server {
