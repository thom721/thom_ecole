QTabWidget::pane {
    border: none;
    top: -14px
}

QTabBar::tab {
    border: none;
    color: #fff
}

QTabBar::tab:only-one {
    margin: 0;
}

/*Welcome Page*/

QLineEdit,
QComboBox,
QDateEdit {
    background: #fff
}

QComboBox QListView {
    font-size: 12px;
    padding: 4px;
    background-color: #fefefe;
}

QLineEdit,QComboBox {
    border: none;
    border-bottom: 2px solid #1266f1
}

#welcome,
#header_welcome {
    background-color: #fff
}


#btn_welcome_valider {
    border: 1px solid #1266f1;
    padding: 4px;
    border-radius: 5px;
    color: #1266f1;
    width: 50px
}

#btn_welcome_fermer {
    border: 1px solid #f74a4a;
    padding: 4px;
    border-radius: 5px;
    color: #f74a4a;
    width: 50px
}

#error_message {
    color: #f74a4a;
}

#btn_welcome_valider:hover {
    border: 1px solid #1266f1;
    background-color: #1266f1;
    padding: 4px;
    border-radius: 5px;
    color: #fff;
    width: 50px
}

#btn_welcome_fermer:hover {
    border: 1px solid #f74a4a;
    background-color: #f74a4a;
    padding: 4px;
    border-radius: 5px;
    color: #fff;
    width: 50px
}


