#cours_stack{    color: #fcbc05;
    border: 1px solid #fcbc05;
    padding: 4px; border-radius: 5px
}
#programme_stack{    color: #4385f5;
    border: 1px solid #4385f5;
    padding: 4px; border-radius: 5px}

#cours_stack:hover{    color: #fff;
    border: 1px solid #ff8c00; 
    background-color: #ff8c00;
 border-radius: 5px;
    padding: 4px;}

#programme_stack:hover{    color: #fff;
    border: 1px solid #228BE6; 
    background-color: #228BE6;
 border-radius: 5px;
    padding: 4px;}

#cours_stack:checked{
  color: #fff;
    border: 1px solid #fcbc05;
	border-bottom:0px;
    background-color: #fcbc05;
    padding: 4px;
}
#programme_stack:checked{    color: #fff;
    border: 1px solid #228BE6;
	border-bottom:0px;
    background-color: #228BE6;
    padding: 4px;}

