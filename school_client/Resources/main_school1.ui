QComboBox,QLineEdit,QDateEdit {
               
                border: 1px solid #ccc;
                border-radius:5px;
                padding: 5px;
min-height:25px;
max-height:25px; 
background-color: #ffffff;
    color: #1e293b; /* Texte que l'utilisateur tape */
    font-size: 14pt;
            }

QLineEdit::placeholder {
    color: #94a3b8; /* Gris bleuté doux (Slate 400) */
    font: italic; /* Optionnel : pour bien différencier du texte saisi */
font-size: 11pt; 
}
QCheckBox{
background-color: #ffffff;
    color: #1e293b; /* Texte que l'utilisateur tape */
    font-size: 14px;
                border: 1px solid #aaa;
                border-radius:2px; 
}
            
            QComboBox:hover,QDateEdit:focus,QLineEdit:focus,QComboBox:focus,QCheckBox:focus {
                
                border: 1px solid #007bff;
            }
                                        
            QComboBox:disabled::drop-down, QDateEdit:disabled::drop-down{
                background: transparent;
            }

            
            QComboBox:disabled {
                background-color: #afafaf;  /* Gris clair */
                color: #f0f0f0;  /* Texte grisé */
                border: 1px solid #dcdcdc;
            }

