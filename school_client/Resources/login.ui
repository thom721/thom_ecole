}


#search_table_admin{border:none}

#btn_admin{color:#FAB005;}
#btn_user{color:#228BE6}
#btn_pro{color:#40C057}
#btn_etudiant{color:#FA5252}
#btn_cours{color:#0dcaf0}
#btn_faculte{color:#dc3545}
#btn_employee{color:#ffc107}
#btn_total{color:#b23cfd}

