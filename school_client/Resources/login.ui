#user{border: 1px solid #228BE6;}
#professeur{border: 1px solid #40C057;}
#etudiant{border: 1px solid #FA5252;}
#cours{border: 1px solid #0dcaf0;}
#faculte{border: 1px solid #dc3545;}
#employee{border: 1px solid #ffc107;}
#total{border: 1px solid #b23cfd;}

