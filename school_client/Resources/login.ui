#search, #seach_cours, #search_programme, #search_paiement{border:none;}

#add_student, #edit_student, #add_admin, #btn_add_cours, #btn_add_professeur{
		color:#228BE6;
		border: 1px solid #228BE6;
		padding:4px;
      border-radius:5px}

#add_student:hover,
 #edit_student:hover,
#add_admin:hover,
#btn_add_cours:hover,
btn_add_professeur:hover{
		color:#fff;
		border: 1px solid #228BE6;
		background-color:#228BE6;
		padding:4px;
      border-radius:5px}

#add_faculte, #add_annee, #add_frais,#add_niveau,#paiement_mobile{color:#228BE6;border:1px solid #228BE6; padding:3px; border-radius:5px}
#add_faculte:hover, #add_annee:hover, #add_frais:hover,#add_niveau:hover,#paiement_mobile:hover{background-color:#228BE6;color:#fff;border:1px solid #228BE6; padding:4px; border-radius:5px}

#fac_active,#annee_en_cour, #paiement_electronique{color:#00b74a;border:1px solid #00b74a; padding:3px; border-radius:5px}
#fac_active:hover,#annee_en_cour:hover, #paiement_electronique:hover{background-color:#00b74a;color:#fff;border:1px solid #00b74a; padding:4px; border-radius:5px}

#fac_inactive,#universite, #paiement{color:#ffa900;border:1px solid #ffa900; padding:3px; border-radius:5px}
#fac_inactive:hover, #universite:hover, #paiement:hover{background-color:#ffa900;color:#fff;border:1px solid #ffa900; padding:4px; border-radius:5px}

#frais_par_cours, #primaire{color:#39c0ed;border:1px solid #39c0ed; padding:3px; border-radius:5px}
#frais_par_cours:hover,#primaire:hover{background-color:#39c0ed;color:#fff;border:1px solid #39c0ed; padding:4px; border-radius:5px}

#frais_par_session, #secondaire{color:#00b74a;border:1px solid #00b74a; padding:3px; border-radius:5px}
#frais_par_session:hover,secondaire:hover{background-color:#00b74a;color:#fff;border:1px solid #00b74a; padding:3px; border-radius:5px}

#frais_par_annee{color:#ffa900;border:1px solid #ffa900; padding:3px; border-radius:5px}
#frais_par_annee:hover{background-color:#ffa900;color:#fff;border:1px solid #ffa900; padding:3px; border-radius:5px}

#btn_add_note, #btn_edit_note,#aff_admin, #btn_afficher_cours{
		color:#ffa900;
		border: 1px solid #ffa900;
		padding:5px;
      border-radius:5px}

#btn_add_note:hover,
 #btn_edit_note:hover,
#aff_admin:hover,
#btn_afficher_cours:hover{
