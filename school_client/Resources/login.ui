#profileCount, #frame_8{background-color:#fdfdfd;border-radius:15px;}

#frame_29, #affiche_entre_table_student, #search_admin, #entry_admin, #frame_search_cours, #combo_entry_cours, #combo_faculte, #combo_annee, #combo_niveau, #entry_professeur, #search_professeur,#combo_entry_programme, #frame_search_programme,#frame_search_paiement, #entry_paiement, #id_etudiant,#combo_id_prof,#combo_annee_prog,#combo_fac, #combo_niveau_prog,#combo_cours_prog,#combo_jours{
