    <string notr="true">*{background:transparent}
#shadow_window{background-color:#fefefe;border-radius:7px}

#leftmenu, #left_frame,#header, #header_connexion,#header_welcome{border-top-left-radius:7px;border-bottom-left-radius:7px}
#header, #main{border-top-right-radius:7px;border-bottom-right-radius:7px}
#frame_112, #prog_cours{border-top-right-radius:7px;border-top-left-radius:7px}
#prog_cours{border-bottom-right-radius:7px;border-bottom-left-radius:7px}

#leftmenu, #left_frame {background-color:#228BE6;}
#footer{background-color:#e1e1e1;}
#main_with_shadow{background-color:#fff;}

#header, #widget_gestion_free, #widget_gestion_annee, #widget_gestion_faculte, #widget_gestion_niveau, #widget_paiement,#frame_paiement_shadow, #admin, #prog_cours{background-color:#fff}
 #widget_gestion_free, #widget_gestion_annee, #widget_gestion_faculte,#widget_gestion_niveau, #widget_paiement,#frame_paiement_shadow{border-radius:10px}

#btn_close, #btn_min, #btn_profile, #minimize, #btn_toggle, #btn_admin,#btn_pro,#btn_etudiant,#btn_user,#btn_left_admin,#btn_left_cours,#btn_left_etudiant,#btn_left_faculte,#btn_left_home,#btn_left_prof,#logout,#myprofile{background:transparent}

#titre_toggle, #header_titre{color:#287bff;}

#admin, #etudiant,#professeur, #user,#cours,#employee,#faculte,#total,#frame{
	background-color:#fff;
	border-radius:10px;
}


#frame_msg{background-color:#fed6dd; border-top-right-radius:10px;border-top-left-radius:10px;border-color:#fdc1cc}
#label_msg{color:#951d32}

