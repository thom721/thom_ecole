#frame:hover{color:#fff}*/

#btn_left_admin,#btn_left_cours,#btn_left_etudiant,#btn_left_prof,#btn_left_home,#btn_left_paiement,#btn_settings, #btn_about,#btn_left_notes,#btn_left_rapport,#btn_letf_vente,#btn_left_promus{color:#fff;font-weight:bold; text-align:start;}

#btn_left_admin:hover,
#btn_left_cours:hover,
#btn_left_etudiant:hover,
#btn_left_prof:hover,
