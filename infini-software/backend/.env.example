# Copier en .env et remplir avant de lancer le serveur.

# Secret utilisé pour signer les JWT admin. Générer avec : openssl rand -hex 32
JWT_SECRET=change-me

# Secret utilisé par genere_key.py pour dériver les clés d'activation.
# DOIT être identique à celui lu par ecole_nginx (même variable KEY_SECRET) :
# secret PARTAGÉ entre infini-software et chaque installation ecole_nginx,
# pas un secret par-installation. Le changer sans redéployer la même valeur
# partout invalide toutes les clés déjà émises.
KEY_SECRET=CLE_SECRETE_PERSO

# --- MonCash (Digicel Haïti) ---
# Identifiants obtenus depuis le portail marchand MonCash (sandbox ou prod).
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_BASE_URL=https://sandbox.moncashbutton.digicelgroup.com
MONCASH_GATEWAY_URL=https://sandbox.moncashbutton.digicelgroup.com/Moncash-middleware

# --- NatCash (Natcom) — intégration pas encore implémentée, voir app/payments/natcash.py
NATCASH_CLIENT_ID=
NATCASH_CLIENT_SECRET=

# --- Stripe — en attente, voir app/payments/stripe_provider.py
STRIPE_SECRET_KEY=

# --- Mode test ---
# Si "true", /api/licence/payer valide le paiement immédiatement sans appeler
# le fournisseur réel. NE JAMAIS laisser à "true" en production.
PAYMENT_TEST_MODE=false
